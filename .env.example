# Expo Web no mesmo computador
EXPO_PUBLIC_API_BASE_URL=https://localhost:7170/api

# Dispositivo fisico na mesma rede
# Substitua pelo IPv4 do computador
# HTTPS local normalmente exige confiar manualmente no certificado de desenvolvimento no dispositivo.
# EXPO_PUBLIC_API_BASE_URL=https://192.168.0.100:7170/api

# Dispositivo fisico na mesma rede usando HTTP local de desenvolvimento da Forge.Api
# Use quando o certificado HTTPS local nao for confiavel no celular.
# EXPO_PUBLIC_API_BASE_URL=http://192.168.0.100:5113/api

# Android Emulator padrao
# EXPO_PUBLIC_API_BASE_URL=https://10.0.2.2:7170/api
# Alternativa HTTP local para evitar problemas com certificado no emulador
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:5113/api

EXPO_PUBLIC_USER_PROFILE_ID=
